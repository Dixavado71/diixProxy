{
  "manifest_version": 3,
  "name": "Diix Proxy - Network Monitor",
  "version": "2.1.0",
  "description": "Monitor profissional de requisições HTTP(S) em tempo real",
  "permissions": [
    "webRequest",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/devil.png",
      "48": "icons/devil.png",
      "128": "icons/devil.png"
    },
    "default_title": "Diix Proxy Monitor"
  },
  "icons": {
    "16": "icons/devil.png",
    "48": "icons/devil.png",
    "128": "icons/devil.png"
  }
}